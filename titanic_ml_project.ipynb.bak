    "]\n",
    "\n",
    "all_passed = True\n",
    "for check, message in checks:\n",
    "    status = \"✓\" if check else \"✗\"\n",
    "    print(f\"{status} {message}\")\n",
    "    if not check:\n",
    "        all_passed = False\n",
