   "source": "# DEEP EDA: Analyse détaillée des corrélations\nprint(\"\\n\" + \"=\"*70)\nprint(\"DEEP EDA: ANALYSE DÉTAILLÉE DES CORRÉLATIONS\")\nprint(\"=\"*70)\n\n# 1. Detailed correlation analysis with Survival\nnumerical_cols = train_df.select_dtypes(include=[np.number]).columns.tolist()\nsurvival_corr = train_df[numerical_cols].corr()['Survived'].sort_values(ascending=False)\n\nprint(\"\\nCorrelation with Survival (sorted by absolute value):\")\nprint(survival_corr)\n\n# 2. Correlation heatmap with annotations\nfig, axes = plt.subplots(1, 2, figsize=(16, 6))\n\n# Full correlation matrix\nsns.heatmap(correlation_matrix, annot=True, fmt='.2f', cmap='coolwarm', center=0, \n            square=True, ax=axes[0], cbar_kws={'label': 'Correlation'})\naxes[0].set_title('Correlation Matrix - All Numerical Features', fontsize=12, fontweight='bold')\n\n# Top correlations with Survival\ntop_corr = survival_corr[survival_corr.index != 'Survived'].head(10)\ncolors = ['green' if x > 0 else 'red' for x in top_corr.values]\naxes[1].barh(range(len(top_corr)), top_corr.values, color=colors, alpha=0.7)\naxes[1].set_yticks(range(len(top_corr)))\naxes[1].set_yticklabels(top_corr.index)\naxes[1].set_xlabel('Correlation Coefficient')\naxes[1].set_title('Top Features Correlated with Survival', fontsize=12, fontweight='bold')\naxes[1].axvline(x=0, color='black', linestyle='-', linewidth=0.8)\nfor i, v in enumerate(top_corr.values):\n    axes[1].text(v + 0.01 if v > 0 else v - 0.01, i, f'{v:.3f}', va='center', \n                ha='left' if v > 0 else 'right', fontweight='bold')\n\nplt.tight_layout()\nplt.show()\n\n# 3. Interpretation of key correlations\nprint(\"\\n\" + \"=\"*70)\nprint(\"CORRELATION INTERPRETATION:\")\nprint(\"=\"*70)\nprint(\"✓ Sex: Strongest predictor (negative = male, lower survival)\")\nprint(\"✓ Pclass: Negative correlation (higher class number = lower survival)\")\nprint(\"✓ Age: Negative correlation (older passengers less likely to survive)\")\nprint(\"✓ Fare: Positive correlation (higher fare = better survival)\")\nprint(\"✓ FamilySize: Moderate correlation (family status matters)\")\nprint(\"✓ Embarked: Weak correlation (embarkation port has some effect)\")\n\n# 4. Multi-variable interaction analysis\nprint(\"\\n\" + \"=\"*70)\nprint(\"INTERACTION ANALYSIS: Sex × Class × Age\")\nprint(\"=\"*70)\n\nfig, axes = plt.subplots(1, 3, figsize=(16, 5))\n\nfor idx, pclass in enumerate([1, 2, 3]):\n    data_class = train_df[train_df['Pclass'] == pclass]\n    \n    # Create age groups for analysis\n    age_bins = [0, 10, 20, 30, 40, 50, 80]\n    data_class['AgeGroup'] = pd.cut(data_class['Age'], bins=age_bins)\n    \n    # Calculate survival rate by sex and age group\n    survival_by_age_sex = data_class.groupby(['AgeGroup', 'Sex'])['Survived'].agg(['sum', 'count', 'mean'])\n    \n    # Plot\n    male_data = data_class[data_class['Sex'] == 'male'].groupby(pd.cut(data_class[data_class['Sex'] == 'male']['Age'], bins=age_bins))['Survived'].mean() * 100\n    female_data = data_class[data_class['Sex'] == 'female'].groupby(pd.cut(data_class[data_class['Sex'] == 'female']['Age'], bins=age_bins))['Survived'].mean() * 100\n    \n    x_pos = np.arange(len(age_bins) - 1)\n    width = 0.35\n    \n    # Handle NaN values\n    male_data = male_data.fillna(0)\n    female_data = female_data.fillna(0)\n    \n    axes[idx].bar(x_pos - width/2, male_data.values, width, label='Male', color='steelblue', alpha=0.7)\n    axes[idx].bar(x_pos + width/2, female_data.values, width, label='Female', color='coral', alpha=0.7)\n    axes[idx].set_xlabel('Age Group')\n    axes[idx].set_ylabel('Survival Rate (%)')\n    axes[idx].set_title(f'Survival Rate by Age & Sex - Class {pclass}', fontweight='bold')\n    axes[idx].set_xticks(x_pos)\n    age_labels = [f'{age_bins[i]}-{age_bins[i+1]}' for i in range(len(age_bins)-1)]\n    axes[idx].set_xticklabels(age_labels, rotation=45)\n    axes[idx].legend()\n    axes[idx].set_ylim([0, 105])\n    \n    print(f\"\\nClass {pclass} - Survival rates by Age & Sex:\")\n    print(f\"  Male: {male_data.values}\")\n    print(f\"  Female: {female_data.values}\")\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n\" + \"=\"*70)\nprint(\"KEY INSIGHTS - INTERACTIONS:\")\nprint(\"=\"*70)\nprint(\"✓ Women and children had higher survival rates across all classes\")\nprint(\"✓ Class 1 females: highest survival rate regardless of age\")\nprint(\"✓ Class 3 males: lowest survival rate, especially older males\")\nprint(\"✓ Age effect is stronger in lower classes (3 & 2) than in class 1\")",
