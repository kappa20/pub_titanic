   "source": [
    "# Missing values analysis\n",
    "print(\"\\nMissing Values Analysis:\")\n",
    "missing_data = pd.DataFrame({\n",
    "    'Column': train_df.columns,\n",
    "    'Missing_Count': train_df.isnull().sum(),\n",
    "    'Percentage': (train_df.isnull().sum() / len(train_df)) * 100\n",
    "})\n",
    "missing_data = missing_data[missing_data['Missing_Count'] > 0].sort_values('Percentage', ascending=False)\n",
    "print(missing_data)\n",
    "\n",
    "# Visualize missing values\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "msno.matrix(train_df, ax=ax, sparkline=False)\n",
    "plt.title('Missing Values in Training Data', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "source": "# DEEP EDA: Analyse de l'influence de l'âge sur la survie\nprint(\"\\n\" + \"=\"*70)\nprint(\"DEEP EDA: INFLUENCE DE L'ÂGE SUR LA SURVIE\")\nprint(\"=\"*70)\n\nfig, axes = plt.subplots(2, 2, figsize=(15, 10))\n\n# 1. Age vs Survival by Sex\nfor sex in ['male', 'female']:\n    data_sex = train_df[train_df['Sex'] == sex]\n    survived = data_sex[data_sex['Survived'] == 1]['Age'].dropna()\n    not_survived = data_sex[data_sex['Survived'] == 0]['Age'].dropna()\n    \n    ax = axes[0, 0] if sex == 'male' else axes[0, 1]\n    ax.hist([not_survived, survived], bins=30, label=['Did not survive', 'Survived'], \n            alpha=0.7, color=['#d62728', '#2ca02c'])\n    ax.set_title(f'Age Distribution by Survival Status - {sex.upper()}', fontweight='bold')\n    ax.set_xlabel('Age')\n    ax.set_ylabel('Frequency')\n    ax.legend()\n    \n    # Add statistics\n    print(f\"\\n{sex.upper()}:\")\n    print(f\"  Mean age (survived): {survived.mean():.1f} years\")\n    print(f\"  Mean age (not survived): {not_survived.mean():.1f} years\")\n    print(f\"  Median age (survived): {survived.median():.1f} years\")\n    print(f\"  Median age (not survived): {not_survived.median():.1f} years\")\n\n# 2. Age vs Survival by Passenger Class\nfor pclass in [1, 2, 3]:\n    data_class = train_df[train_df['Pclass'] == pclass]\n    survived = data_class[data_class['Survived'] == 1]['Age'].dropna()\n    not_survived = data_class[data_class['Survived'] == 0]['Age'].dropna()\n    \n    ax = axes[1, 0] if pclass == 1 else (axes[1, 1] if pclass == 2 else None)\n    if ax is not None:\n        ax.hist([not_survived, survived], bins=25, label=['Did not survive', 'Survived'], \n                alpha=0.7, color=['#d62728', '#2ca02c'])\n        ax.set_title(f'Age Distribution by Survival Status - Class {pclass}', fontweight='bold')\n        ax.set_xlabel('Age')\n        ax.set_ylabel('Frequency')\n        ax.legend()\n\n# Use the last subplot for age statistics by class\nax = axes[1, 1]\nax.clear()\nclass_age_stats = []\nfor pclass in [1, 2, 3]:\n    data_class = train_df[train_df['Pclass'] == pclass]\n    survived_rate = data_class['Survived'].mean() * 100\n    mean_age = data_class['Age'].mean()\n    class_age_stats.append({'Class': pclass, 'Survival Rate': survived_rate, 'Mean Age': mean_age})\n\nstats_df = pd.DataFrame(class_age_stats)\nax2 = ax.twinx()\nax.bar(stats_df['Class'], stats_df['Survival Rate'], color='steelblue', alpha=0.6, label='Survival Rate (%)')\nax2.plot(stats_df['Class'], stats_df['Mean Age'], color='red', marker='o', linewidth=2, markersize=8, label='Mean Age')\nax.set_xlabel('Passenger Class')\nax.set_ylabel('Survival Rate (%)', color='steelblue')\nax2.set_ylabel('Mean Age (years)', color='red')\nax.set_title('Survival Rate vs Mean Age by Class', fontweight='bold')\nax.set_xticks([1, 2, 3])\nplt.tight_layout()\nplt.show()\n\n# Key Insight\nprint(\"\\n\" + \"=\"*70)\nprint(\"KEY INSIGHTS - AGE INFLUENCE:\")\nprint(\"=\"*70)\nprint(\"✓ Age has a strong influence on survival, especially for females\")\nprint(\"✓ Younger passengers (especially children) had higher survival rates\")\nprint(\"✓ Class 1 passengers with higher average age still had better survival rates\")\nprint(\"✓ This suggests age effect is modulated by passenger class and sex\")",
   "metadata": {},
   "execution_count": null,
   "outputs": []
  },
  {
